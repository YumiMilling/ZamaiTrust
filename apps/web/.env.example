# CATSP OS Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase (hosted project) ────────────────────────────────────────────────
# Find these in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── Supabase (local dev: supabase start) ─────────────────────────────────────
# Uncomment when running locally. The anon key is printed by `supabase start`.
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App mode ─────────────────────────────────────────────────────────────────
# Set to 'kiosk' to lock the app to kiosk mode (aggregation point tablets)
# Leave unset or set to 'full' for standard admin/dashboard access
# VITE_APP_MODE=kiosk

# ── Kiosk: physical location ─────────────────────────────────────────────────
# Set when running in kiosk mode. Must match an organisation.id in the DB.
# VITE_KIOSK_ORG_ID=00000000-0000-0000-0000-000000000021
